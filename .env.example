# Application Configurations
APP_NAME="ML-Intrusion-Detection-System"
APP_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-secure-random-secret-key-for-production

# API Configurations
API_V1_STR=/api/v1
HOST=0.0.0.0
PORT=8000

# Database Configurations
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ids_db

# Model Registry Configurations
MODEL_REGISTRY_PATH=models/registry
DEFAULT_MODEL_VERSION=1.0.0

# Logging
LOG_LEVEL=INFO
